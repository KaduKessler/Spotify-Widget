# ============================================
# Authentication Providers (Multi-provider)
# ============================================
# Enable multiple auth methods simultaneously
ENABLE_PASSWORD_AUTH=true
ENABLE_GITHUB_AUTH=true
ENABLE_NONE_AUTH=false

# Legacy (deprecated, use ENABLE_* instead)
# AUTH_PROVIDER=github | password | none

# ============================================
# Password Auth
# ============================================
# Required if ENABLE_PASSWORD_AUTH=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password

# ============================================
# GitHub OAuth
# ============================================
# Required if ENABLE_GITHUB_AUTH=true
# Get credentials: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ============================================
# Application URLs
# ============================================
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# ============================================
# Security
# ============================================
# Generate: openssl rand -hex 32
SESSION_SECRET=your-strong-session-secret-min-32-chars

# ============================================
# Environment
# ============================================
NODE_ENV=development

# ============================================
# Database
# ============================================
DATABASE_URL=file:./data/db.sqlite
